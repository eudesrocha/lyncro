# =============================================
# Lyncro — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================

# --- Servidor ---
PORT=3000

# --- Supabase (obrigatório para autenticação do Host) ---
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Twilio (opcional — fornece TURN servers para NAT traversal) ---
# Se não configurado, usa apenas STUN (pode falhar em redes restritivas)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- CORS (obrigatório em produção) ---
# Domínio do seu deploy, ex: https://lyncro.onrender.com
ALLOWED_ORIGIN=https://seu-dominio.com

# --- Supabase Service Role (server-side only — NUNCA exponha no browser) ---
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe ---
# Chave secreta do Stripe (Dashboard → Developers → API Keys → Secret key)
STRIPE_SECRET_KEY=sk_live_...

# --- Stripe Webhook ---
# Segredo do webhook (Dashboard → Developers → Webhooks → Signing secret)
# Em dev local use: stripe listen --forward-to localhost:3000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Stripe Price IDs do plano PRO ---
# Dashboard → Products → Lyncro PRO → copie o Price ID de cada variante
# BRL
STRIPE_PRICE_PRO_BRL_MONTHLY=price_...     # R$ 59,90/mês
STRIPE_PRICE_PRO_BRL_SEMIANNUAL=price_...  # R$ 299,90/6 meses
STRIPE_PRICE_PRO_BRL_ANNUAL=price_...      # R$ 499,90/ano
# USD
STRIPE_PRICE_PRO_USD_MONTHLY=price_...     # $ 14.90/mo
STRIPE_PRICE_PRO_USD_SEMIANNUAL=price_...  # $ 75.90/6mo
STRIPE_PRICE_PRO_USD_ANNUAL=price_...      # $ 125.00/yr
# EUR
STRIPE_PRICE_PRO_EUR_MONTHLY=price_...     # € 14,90/mois
STRIPE_PRICE_PRO_EUR_SEMIANNUAL=price_...  # € 75,90/6mo
STRIPE_PRICE_PRO_EUR_ANNUAL=price_...      # € 125,00/an
