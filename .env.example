# =============================================
# Lyncro — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================

# --- Servidor ---
PORT=3000

# --- Supabase (obrigatório para autenticação do Host) ---
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Twilio (opcional — fornece TURN servers para NAT traversal) ---
# Se não configurado, usa apenas STUN (pode falhar em redes restritivas)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- CORS (obrigatório em produção) ---
# Domínio do seu deploy, ex: https://lyncro.onrender.com
ALLOWED_ORIGIN=https://seu-dominio.com
